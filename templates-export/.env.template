# OpenClaw .env Template (完整版)

# 複製此文件為 ~/.openclaw/.env 並填充你的實際 values

# ============================================
# AI Models API Keys
# ============================================

# Aliyun (Qwen) - 主要模型
# 獲取：https://bailian.console.aliyun.com/
ALIYUN_API_KEY=sk-your-api-key-here

# DeepSeek - 可選
# 獲取：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-api-key-here

# OpenRouter - 可選 (MiniMax Vision)
# 獲取：https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-your-api-key-here

# ============================================
# Messaging Platforms
# ============================================

# Discord Bot Token (Main Bot)
# Discord Developer Portal → Your App → Bot → Token
DISCORD_BOT_TOKEN=MTQ3NjUwMTI4Nzc0MTk1MjEwMA.your-token-here

# Discord Game Bot Token (Optional)
# Discord Developer Portal → Your App → Bot → Token
DISCORD_GAMEBOT_TOKEN=MTQ3ODE5NzIwMTcwMzUzODc5OA.your-token-here

# Telegram Bot Token
# @BotFather → New Bot → Token
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ============================================
# Discord IDs (重要！)
# ============================================
# 獲取方法：Discord → 設置 → 進階 → 開發者模式 → 右鍵複製 ID

# 擁有者 Discord User ID
DISCORD_USER_ID_OWNER=1392035049251274855

# 服務器 Guild ID
DISCORD_GUILD_ID=1476504374221213729

# 頻道 Channel IDs
DISCORD_CHANNEL_CODING_ID=1476504635161444432
DISCORD_CHANNEL_RESEARCH_ID=1476504685027528855
DISCORD_CHANNEL_ADMIN_ID=1476504712072138862

# ============================================
# Gateway Configuration
# ============================================

# Gateway Auth Token (自定義一個強的 random string)
# 生成：openssl rand -hex 32
GATEWAY_AUTH_TOKEN=your-gateway-secret-token-here

# ============================================
# Web Services (可選)
# ============================================

# Brave Search API
# 獲取：https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=your-brave-search-key-here

# Tavily API (可選)
# 獲取：https://tavily.com/
TAVILY_API_KEY=your-tavily-key-here

# ============================================
# Other Services (可選)
# ============================================

# Supabase (如果使用 Dashboard)
# 獲取：https://app.supabase.com/
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Zeabur (如果部署到 Zeabur)
# 獲取：https://zeabur.com/
ZEABUR_API_KEY=your-zeabur-key-here

# ============================================
# Notes
# ============================================
# 1. 此文件應該加入 .gitignore
# 2. 不要 commit 此文件到 Git
# 3. 只在本機保存，不要分享
# 4. 定期更換 secrets
# 5. 使用強的 random strings
# 6. 所有 Discord IDs 必須是數字字符串
